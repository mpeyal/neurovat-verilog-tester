# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# local Verilog-A toolchain binaries + build artifacts (downloaded, not source)
tools/vasim/bin/
tools/vasim/*.osdi

# compiler / simulator build artifacts (regenerated, not source)
*.osdi
*.exp
*.lib
*.o[0-9]
probe*_tmp.*

# root-level scratch / screenshot scripts
/_*.py

# non-standard .ava backups (va_scan only reads .va)
*.ava

# generated result figures + data (regenerated by run_*.py / the GUI)
results/*.png
results/*.csv

# downloaded datasets (MNIST etc.) + saved-model JSON (outputs, not source)
/datasets/
results/models/
/aved_model/

# agent / GUI transient outputs
results/.agent_backup/
results/agent_snapshot.json
results/agent_spec.json
results/agent_out.json
results/neuro_snapshot.json
results/gui_*.csv

# test + screenshot artifacts (generated)
results/_*.png
results/ui_*.png

# editor / OS cruft
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Claude Code local config
.claude/

# agent scratch plots in results/
results/stdp_plot.py
results/stdp_plot.png
